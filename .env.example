# =============================================================================
# Watchflare: Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Installation modes:
#   Docker: docker-compose.yml reads this file at the repo root.
#   Binary: place .env next to the watchflare-app binary.
#   Contributor: copy to repo root, then run `go run ./backend` and `npm run dev`.
#
# Variables marked [Docker only] are used exclusively by docker-compose.
# Variables marked [contributor] are only needed for the manual dev setup.
# All others apply to both Docker and binary installs.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (PostgreSQL / TimescaleDB)
# -----------------------------------------------------------------------------
# [Docker only] These are used by the postgres service in docker-compose.yml
# as well as read by the backend container via the same .env file.
POSTGRES_USER=watchflare
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=watchflare

# Host where PostgreSQL is reachable from the backend.
# Docker: docker-compose overrides this to "postgres" (the service name).
# Binary / contributor: use "localhost" (or your DB host).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable


# -----------------------------------------------------------------------------
# Secrets (required, generate with: openssl rand -base64 32)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_random_32_char_string

# Required to encrypt notification channel credentials at rest (SMTP password, Shoutrrr URLs).
# Keep separate from JWT_SECRET.
NOTIFICATION_ENCRYPTION_KEY=change_me_to_a_random_32_char_string


# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
# [Docker only] External port exposed on the host for HTTP (default: 8080).
# HUB_PORT=8080

# gRPC port for agent connections (default: 50051).
# GRPC_PORT=50051


# -----------------------------------------------------------------------------
# TLS (gRPC / agent connections)
# -----------------------------------------------------------------------------
# TLS_MODE=auto: Hub generates a self-signed CA + cert automatically.
# TLS_MODE=custom: provide your own cert/key/CA files below.
TLS_MODE=auto

# PKI directory where auto-generated certs are stored.
# Binary / contributor: ./data/pki   (relative to the binary / repo root)
# Docker / production:  /var/lib/watchflare/pki
TLS_PKI_DIR=./data/pki

# Custom TLS files: only used when TLS_MODE=custom.
# TLS_CERT_FILE=/etc/watchflare/tls/cert.pem
# TLS_KEY_FILE=/etc/watchflare/tls/key.pem
# TLS_CA_FILE=/etc/watchflare/tls/ca.pem


# -----------------------------------------------------------------------------
# Cookie Security
# -----------------------------------------------------------------------------
# The Secure flag on the JWT cookie is auto-detected per request (recommended):
#   - Direct HTTPS (TLS_CERT_FILE / TLS_KEY_FILE configured) → Secure on
#   - Behind a trusted reverse proxy sending X-Forwarded-Proto: https → Secure on
#   - Plain HTTP with no proxy → Secure off
#
# Use COOKIE_SECURE only to force-override auto-detection:
# COOKIE_SECURE=true    # Force Secure on  (requires HTTPS, or browsers will reject the cookie)
# COOKIE_SECURE=false   # Force Secure off (not recommended in production)

# Trusted proxy IPs allowed to set X-Forwarded-Proto (default: loopback only).
# Add your reverse proxy's IP if it runs on a different host.
# TRUSTED_PROXIES=127.0.0.1,::1

# Cookie domain (set to your domain when using a reverse proxy or custom domain).
# COOKIE_DOMAIN=watchflare.example.com


# -----------------------------------------------------------------------------
# CORS (contributor / dev only)
# -----------------------------------------------------------------------------
# Not needed when the frontend is embedded in the binary (Docker + binary installs).
# CORS_ORIGINS=http://localhost:5173


# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Environment: development | production
# ENV=production

# gRPC HMAC timestamp window in seconds (default: 300 = ±5 minutes).
# GRPC_TIMESTAMP_WINDOW=300
