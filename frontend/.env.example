# =============================================================================
# Frontend — Dev Server Configuration (contributor / manual setup only)
# =============================================================================
# This file is NOT used in Docker or binary installs.
# The production frontend is embedded in the Hub binary at build time.
#
# Copy to frontend/.env and uncomment the variables you need.
# =============================================================================

# Hostnames (other than localhost) allowed to access the Vite dev server.
# Useful when running npm run dev on a VM or remote machine.
# Separate multiple values with commas.
# VITE_ALLOWED_HOSTS=dev-watchflare.mylab.int,192.168.1.42

# Override the proxy target for /api/v1 requests (default: http://localhost:8080).
# Useful if your Hub runs on a different host or port.
# BACKEND_URL=http://localhost:8080
